# ─── Embedding model ──────────────────────────────────────────────────────────
# Supported providers: ollama, openai (covers any OpenAI-compatible endpoint)

EMBED_PROVIDER=ollama
EMBED_MODEL=qwen3-embedding:4b
EMBED_BASE_URL=http://localhost:11434
EMBED_API_KEY=

# OpenAI / OpenAI-compatible example:
# EMBED_PROVIDER=openai
# EMBED_MODEL=text-embedding-3-small
# EMBED_BASE_URL=https://api.openai.com/v1   # or http://lmstudio:1234/v1, etc.
# EMBED_API_KEY=sk-...

# ─── Summary model ────────────────────────────────────────────────────────────
# Supported providers: ollama, openai, anthropic

SUMMARY_PROVIDER=ollama
SUMMARY_MODEL=minimax-m2.7:cloud
SUMMARY_BASE_URL=http://localhost:11434
SUMMARY_API_KEY=

# Anthropic example:
# SUMMARY_PROVIDER=anthropic
# SUMMARY_MODEL=claude-haiku-4-5-20251001
# SUMMARY_BASE_URL=https://api.anthropic.com
# SUMMARY_API_KEY=sk-ant-...

# OpenAI example:
# SUMMARY_PROVIDER=openai
# SUMMARY_MODEL=gpt-4o-mini
# SUMMARY_BASE_URL=https://api.openai.com/v1
# SUMMARY_API_KEY=sk-...

# ─── Indexer ──────────────────────────────────────────────────────────────────

REPO_PATH=/path/to/your/repo
OUTPUT_PATH=./index
MAX_FILE_SIZE=100000
CHUNK_SIZE=400
CHUNK_OVERLAP=80

# ─── MCP server ───────────────────────────────────────────────────────────────

PORT=3000
MCP_API_TOKEN=dev-token
INTERNAL_TOKEN=
INDEX_PATH=./index
